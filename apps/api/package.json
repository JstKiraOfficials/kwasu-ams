{
  "name": "@kwasu-ams/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start:dev": "tsx --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@fastify/cookie": "9.4.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@fastify/websocket": "^11.2.0",
    "@kwasu-ams/types": "workspace:*",
    "@kwasu-ams/utils": "workspace:*",
    "@prisma/client": "^6.19.3",
    "@sentry/node": "^10.52.0",
    "@t3-oss/env-core": "^0.13.11",
    "argon2": "^0.44.0",
    "bullmq": "^5.77.3",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "firebase-admin": "^13.9.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "otpauth": "^9.5.1",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@kwasu-ams/config": "workspace:*",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^25.6.2",
    "@types/pdfkit": "^0.17.6",
    "@vitest/coverage-v8": "^4.1.5",
    "prisma": "^6.19.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
