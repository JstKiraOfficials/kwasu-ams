generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DATABASE_DIRECT_URL")
  extensions = [pgcrypto]
}

// =============================================================================
// Enums
// =============================================================================

enum Role {
  SUPER_ADMIN
  ACADEMIC_AFFAIRS
  VICE_CHANCELLOR
  DEAN
  HOD
  EXAM_OFFICER
  LECTURER
  STUDENT
}

enum DeviceStatus {
  ACTIVE
  REVOKED
  PENDING_APPROVAL
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  PASSWORD_CHANGED
  TOTP_ENROLLED
  TOTP_RESET
  ACCOUNT_LOCKED
  ACCOUNT_UNLOCKED
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  ATTENDANCE_RECORDED
  ATTENDANCE_OVERRIDDEN
  EXCUSE_SUBMITTED
  EXCUSE_APPROVED
  EXCUSE_REJECTED
  EXCUSE_APPEALED
  HOD_EXCUSE_APPROVED
  HOD_EXCUSE_REJECTED
  ELIGIBILITY_COMPUTED
  ELIGIBILITY_OVERRIDDEN
  SESSION_CREATED
  SESSION_OPENED
  SESSION_CLOSED
  SESSION_LOCKED
  DEVICE_REGISTERED
  DEVICE_REVOKED
  BULK_IMPORT_STARTED
  BULK_IMPORT_COMPLETED
  REPORT_GENERATED
  WEBHOOK_FIRED
  SYSTEM_SETTING_CHANGED
  DATA_EXPORT_REQUESTED
}

enum AnomalyType {
  GPS_PRECISION_SPOOFING
  GPS_VELOCITY_SPOOFING
  MOCK_LOCATION_DETECTED
  OUTSIDE_NIGERIA_BOUNDS
  CONCURRENT_SESSION_CONFLICT
  BOUNDARY_CLUSTERING
  LAST_MINUTE_PATTERN
  CLUSTER_IDENTICAL_GPS // Timestamp-based proxy — GPS is never stored (NDPA compliance)
  REPEATED_DAY_PATTERN
  HOD_AWARENESS_FLAG
}

enum NotificationChannel {
  PUSH
  SMS
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketCategory {
  ATTENDANCE_DISPUTE
  ACCOUNT_ACCESS
  TECHNICAL_ISSUE
  EXCUSE_QUERY
  ELIGIBILITY_QUERY
  OTHER
}

enum SemesterType {
  FIRST
  SECOND
  THIRD // Some programmes have a third semester
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

// =============================================================================
// Models
// =============================================================================

/// Central identity model. Every person in the system has exactly one User record.
model User {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  identifier         String    @unique // Matric number or Staff ID — normalised to uppercase
  fullName           String
  email              String    @unique
  phone              String
  role               Role
  scopeId            String?   @db.Uuid // facultyId, departmentId, or null for SUPER_ADMIN/VC
  passwordHash       String // Argon2id hash
  mustChangePassword Boolean   @default(true)
  totpSecret         String? // AES-256 encrypted TOTP secret; null until TOTP enrolled
  totpEnrolled       Boolean   @default(false)
  totpBackupCodes    String[] // SHA-256 hashed backup codes; shown once then stored hashed
  failedAttempts     Int       @default(0)
  lockoutUntil       DateTime?
  languagePreference String    @default("en") // "en" or "yo"
  fcmToken           String? // Firebase Cloud Messaging token for push notifications
  isActive           Boolean   @default(true)
  deletedAt          DateTime? // Soft delete timestamp
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  student        Student?
  lecturer       Lecturer?
  deviceBindings DeviceBinding[]
  auditLogsActed AuditLog[]      @relation("AuditLogActor")
  notifications  Notification[]
  supportTickets SupportTicket[]

  @@index([role])
  @@index([scopeId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("users")
}

/// Device fingerprint binding per student. Max 1 primary + 1 secondary per user.
model DeviceBinding {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String       @db.Uuid
  deviceFingerprint String // Unique device identifier from React Native device API
  platform          String // "ios" or "android"
  deviceModel       String?
  osVersion         String?
  isPrimary         Boolean      @default(false)
  status            DeviceStatus @default(ACTIVE)
  registeredAt      DateTime     @default(now())
  lastSeenAt        DateTime?
  revokedAt         DateTime?
  revokedReason     String?

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, deviceFingerprint])
  @@index([userId])
  @@index([status])
  @@map("device_bindings")
}

/// Append-only audit trail. No updatedAt. RLS policy (Phase 05) prevents UPDATE/DELETE.
model AuditLog {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId    String      @db.Uuid
  actorRole  Role
  action     AuditAction
  entityType String // e.g., "AttendanceRecord", "ExcuseLetter", "User"
  entityId   String?     @db.Uuid
  beforeJson Json? // Snapshot of entity state before change
  afterJson  Json? // Snapshot of entity state after change
  ipAddress  String?
  userAgent  String?
  metadata   Json? // Additional context (e.g., reason, session ID)
  createdAt  DateTime    @default(now())

  actor User @relation("AuditLogActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Soft flag for suspicious check-in behaviour. Not auto-bans — surfaced for human review.
model AnomalyFlag {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId    String      @db.Uuid
  sessionId    String?     @db.Uuid
  flagType     AnomalyType
  description  String
  isReviewed   Boolean     @default(false)
  reviewedById String?     @db.Uuid
  reviewedAt   DateTime?
  reviewAction String? // "CONFIRMED_PRESENT", "CONFIRMED_ABSENT", "ESCALATED"
  reviewNote   String?
  createdAt    DateTime    @default(now())

  student Student @relation(fields: [studentId], references: [id])

  @@unique([studentId, sessionId, flagType]) // Idempotency guard — prevents duplicate flags
  @@index([studentId])
  @@index([sessionId])
  @@index([flagType])
  @@index([isReviewed])
  @@map("anomaly_flags")
}

/// Push, SMS, and email delivery records.
model Notification {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recipientId   String             @db.Uuid
  channel       NotificationChannel
  templateKey   String // e.g., "session-open", "marked-absent"
  language      String             @default("en") // "en" or "yo"
  subject       String? // Email subject only
  body          String
  status        NotificationStatus @default(PENDING)
  externalId    String? // FCM message ID, SMS gateway ID
  failureReason String?
  sentAt        DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime           @default(now())

  recipient User @relation(fields: [recipientId], references: [id])

  @@index([recipientId])
  @@index([status])
  @@index([channel])
  @@index([createdAt])
  @@map("notifications")
}

/// User-submitted support tickets.
model SupportTicket {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  submittedById String         @db.Uuid
  category      TicketCategory
  subject       String
  description   String
  status        TicketStatus   @default(OPEN)
  assignedRole  Role?
  assignedToId  String?        @db.Uuid
  resolution    String?
  resolvedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  submittedBy User @relation(fields: [submittedById], references: [id])

  @@index([submittedById])
  @@index([status])
  @@index([category])
  @@map("support_tickets")
}

// =============================================================================
// Forward declarations — models defined in Phase 04
// These stubs allow Phase 03 relations to compile without errors.
// They will be replaced with full definitions in Phase 04.
// =============================================================================

model AttendanceRecord {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enrollmentId String   @db.Uuid
  studentId    String   @db.Uuid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  enrollment CourseEnrollment @relation(fields: [enrollmentId], references: [id])
  student    Student          @relation(fields: [studentId], references: [id])

  @@map("attendance_records")
}

model ExcuseLetter {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id])

  @@map("excuse_letters")
}

model ExamEligibility {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enrollmentId     String   @db.Uuid
  semesterId       String   @db.Uuid
  studentId        String   @db.Uuid
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  enrollment CourseEnrollment @relation(fields: [enrollmentId], references: [id])
  semester   Semester         @relation(fields: [semesterId], references: [id])
  student    Student          @relation(fields: [studentId], references: [id])

  @@map("exam_eligibilities")
}

model CourseSession {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sectionId  String   @db.Uuid
  venueId    String   @db.Uuid
  lecturerId String?  @db.Uuid
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  section  CourseSection @relation(fields: [sectionId], references: [id])
  venue    Venue         @relation(fields: [venueId], references: [id])
  lecturer Lecturer?     @relation(fields: [lecturerId], references: [id])

  @@map("course_sessions")
}

// =============================================================================
// Academic Structure Models (Phase 03)
// =============================================================================

model University {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique // "Kwara State University"
  shortName String   @unique // "KWASU"
  address   String
  website   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  faculties Faculty[]

  @@map("universities")
}

model Faculty {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  universityId String   @db.Uuid
  name         String // e.g., "Faculty of Sciences"
  code         String   @unique // e.g., "SCI"
  deanId       String?  @db.Uuid // References User with role DEAN
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  university  University   @relation(fields: [universityId], references: [id])
  departments Department[]

  @@unique([universityId, name])
  @@index([universityId])
  @@map("faculties")
}

model Department {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facultyId String   @db.Uuid
  name      String // e.g., "Department of Biology"
  code      String   @unique // e.g., "BIO"
  hodId     String?  @db.Uuid // References User with role HOD
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  faculty    Faculty     @relation(fields: [facultyId], references: [id])
  programmes Programme[]
  courses    Course[]
  lecturers  Lecturer[]

  @@unique([facultyId, name])
  @@index([facultyId])
  @@map("departments")
}

model Programme {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  departmentId  String   @db.Uuid
  name          String // e.g., "B.Sc. Biology"
  code          String   @unique // e.g., "BSC-BIO"
  durationYears Int // e.g., 4 for a 4-year programme
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  department Department @relation(fields: [departmentId], references: [id])
  students   Student[]

  @@unique([departmentId, name])
  @@index([departmentId])
  @@map("programmes")
}

model AcademicSession {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique // e.g., "2024/2025"
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false) // Only one session active at a time
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  semesters Semester[]

  @@map("academic_sessions")
}

model Semester {
  id                     String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  academicSessionId      String          @db.Uuid
  type                   SemesterType
  startDate              DateTime
  endDate                DateTime
  examStartDate          DateTime?
  eligibilityComputeDate DateTime? // Admin-configured trigger date for eligibility computation
  eligibilityThreshold   Float           @default(75.0) // NUC minimum; configurable per semester
  appealWindowDays       Int             @default(5)
  maxApprovedExcuses     Int             @default(4)
  isActive               Boolean         @default(false)
  isFrozen               Boolean         @default(false) // True after exam period starts
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  academicSession   AcademicSession   @relation(fields: [academicSessionId], references: [id])
  timetableEntries  TimetableEntry[]
  courseSections    CourseSection[]
  examEligibilities ExamEligibility[]

  @@unique([academicSessionId, type])
  @@index([academicSessionId])
  @@index([isActive])
  @@map("semesters")
}

model Course {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  departmentId String   @db.Uuid
  code         String   @unique // e.g., "BIO201"
  title        String // e.g., "General Biology II"
  creditUnits  Int
  level        Int // 100, 200, 300, 400, 500, 600
  isElective   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department Department    @relation(fields: [departmentId], references: [id])
  sections   CourseSection[]

  @@index([departmentId])
  @@index([level])
  @@map("courses")
}

model CourseSection {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId      String   @db.Uuid
  semesterId    String   @db.Uuid
  sectionLabel  String // "A", "B", "C"
  lecturerId    String?  @db.Uuid
  maxEnrollment Int      @default(200)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  course           Course             @relation(fields: [courseId], references: [id])
  semester         Semester           @relation(fields: [semesterId], references: [id])
  lecturer         Lecturer?          @relation(fields: [lecturerId], references: [id])
  enrollments      CourseEnrollment[]
  sessions         CourseSession[]
  timetableEntries TimetableEntry[]

  @@unique([courseId, semesterId, sectionLabel])
  @@index([courseId])
  @@index([semesterId])
  @@index([lecturerId])
  @@map("course_sections")
}

model CourseEnrollment {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId       String    @db.Uuid
  courseSectionId String    @db.Uuid
  isCarryOver     Boolean   @default(false)
  enrolledAt      DateTime  @default(now())
  droppedAt       DateTime?

  student           Student           @relation(fields: [studentId], references: [id])
  courseSection     CourseSection     @relation(fields: [courseSectionId], references: [id])
  attendanceRecords AttendanceRecord[]
  examEligibilities ExamEligibility[]

  @@unique([studentId, courseSectionId])
  @@index([studentId])
  @@index([courseSectionId])
  @@map("course_enrollments")
}

model Venue {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String // e.g., "LT1 — Main Lecture Theatre"
  buildingName   String
  latitude       Float // Venue's registered GPS latitude (stored — not student GPS)
  longitude      Float // Venue's registered GPS longitude (stored — not student GPS)
  geofenceRadius Int      @default(50) // Metres; valid range 30–150 enforced at app layer
  capacity       Int
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  timetableEntries TimetableEntry[]
  sessions         CourseSession[]

  @@index([isActive])
  @@map("venues")
}

model TimetableEntry {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseSectionId String    @db.Uuid
  semesterId      String    @db.Uuid
  venueId         String    @db.Uuid
  dayOfWeek       DayOfWeek
  startTime       String // "HH:MM" 24-hour format, e.g., "08:00"
  endTime         String // "HH:MM" 24-hour format, e.g., "10:00"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  courseSection CourseSection @relation(fields: [courseSectionId], references: [id])
  semester      Semester      @relation(fields: [semesterId], references: [id])
  venue         Venue         @relation(fields: [venueId], references: [id])

  @@unique([dayOfWeek, startTime, venueId, semesterId]) // Prevents duplicate venue slots
  @@unique([dayOfWeek, startTime, courseSectionId, semesterId]) // Prevents duplicate section slots
  @@index([courseSectionId])
  @@index([semesterId])
  @@index([venueId])
  @@index([dayOfWeek])
  @@map("timetable_entries")
}

/// Student identity and academic profile.
model Student {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @unique @db.Uuid
  matricNumber String   @unique // Uppercase; validated against MATRIC_NUMBER_REGEX at app layer
  programmeId  String   @db.Uuid
  level        Int // 100, 200, 300, 400, 500, 600
  hasCarryOver Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user              User               @relation(fields: [userId], references: [id])
  programme         Programme          @relation(fields: [programmeId], references: [id])
  enrollments       CourseEnrollment[]
  attendanceRecords AttendanceRecord[]
  excuseLetters     ExcuseLetter[]
  examEligibilities ExamEligibility[]
  anomalyFlags      AnomalyFlag[]

  @@index([programmeId])
  @@index([level])
  @@map("students")
}

/// Lecturer identity and academic profile.
model Lecturer {
  id                  String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String  @unique @db.Uuid
  staffId             String  @unique // Validated against STAFF_ID_REGEX at app layer
  departmentId        String  @db.Uuid
  title               String? // e.g., "Dr.", "Prof."
  accountabilityScore Float? // Computed weekly by BullMQ job; visible to HOD+ only
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user             User            @relation(fields: [userId], references: [id])
  department       Department      @relation(fields: [departmentId], references: [id])
  assignedSections CourseSection[]
  sessions         CourseSession[]

  @@index([departmentId])
  @@map("lecturers")
}
