{
  "extends": "@kwasu-ams/config/tsconfig/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@kwasu-ams/types": ["../../packages/types/src/index.ts"],
      "@kwasu-ams/utils": ["../../packages/utils/src/index.ts"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmit": true,
    "isolatedModules": true
  },
  "include": ["**/*.ts", "**/*.tsx", "next-env.d.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
