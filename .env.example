# =============================================================================
# KWASU AMS — Environment Variables Reference
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# PostgreSQL connection string used by Prisma at runtime.
# In production this may point to a connection pooler (e.g. PgBouncer).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://kwasu:kwasu_dev_password@localhost:5432/kwasu_ams

# Direct connection URL used by Prisma Migrate (must bypass any pooler).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_DIRECT_URL=postgresql://kwasu:kwasu_dev_password@localhost:5432/kwasu_ams

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------

# Redis connection string used by BullMQ and ioredis.
# Format: redis://HOST:PORT
REDIS_URL=redis://localhost:6379

# Redis authentication password. Leave empty for local development.
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------

# Secret for signing access tokens. Must be at least 64 hex characters.
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=

# Secret for signing refresh tokens. Must be at least 64 hex characters.
# Must be DIFFERENT from JWT_ACCESS_SECRET.
# Generate with: openssl rand -hex 64
JWT_REFRESH_SECRET=

# Access token lifetime (short-lived).
JWT_ACCESS_EXPIRES_IN=30m

# Refresh token lifetime.
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# TOTP (Two-Factor Authentication)
# -----------------------------------------------------------------------------

# AES-256 encryption key for TOTP secrets stored at rest.
# Must be exactly 32 bytes = 64 hex characters.
# Generate with: openssl rand -hex 32
TOTP_ENCRYPTION_KEY=

# Issuer name displayed in authenticator apps (e.g. Google Authenticator).
TOTP_ISSUER=KWASU AMS

# -----------------------------------------------------------------------------
# AWS S3
# -----------------------------------------------------------------------------

# AWS region where S3 buckets are hosted.
AWS_REGION=eu-west-1

# AWS IAM access key ID (use a least-privilege IAM user, not root).
AWS_ACCESS_KEY_ID=

# AWS IAM secret access key.
AWS_SECRET_ACCESS_KEY=

# S3 bucket name for storing excuse letter documents (PDF/image uploads).
AWS_S3_BUCKET_EXCUSES=kwasu-ams-excuses

# S3 bucket name for generated reports and exam eligibility certificates.
AWS_S3_BUCKET_REPORTS=kwasu-ams-reports

# -----------------------------------------------------------------------------
# Firebase (FCM — Push Notifications)
# -----------------------------------------------------------------------------

# Firebase project ID from the Firebase console.
FIREBASE_PROJECT_ID=

# Firebase service account email (from the downloaded service account JSON).
FIREBASE_CLIENT_EMAIL=

# Firebase service account private key (JSON-escaped, include the full PEM block).
FIREBASE_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# SMS Gateway
# -----------------------------------------------------------------------------

# SMS provider selection. Supported values: africastalking | termii
SMS_PROVIDER=africastalking

# AfricasTalking API key (required when SMS_PROVIDER=africastalking).
AFRICASTALKING_API_KEY=

# AfricasTalking username (required when SMS_PROVIDER=africastalking).
AFRICASTALKING_USERNAME=sandbox

# Termii API key (required when SMS_PROVIDER=termii).
TERMII_API_KEY=

# Sender ID shown on outbound SMS messages (max 11 alphanumeric characters).
SMS_SENDER_ID=KWASU-AMS

# -----------------------------------------------------------------------------
# Sentry (Error Tracking)
# -----------------------------------------------------------------------------

# Sentry Data Source Name — obtained from your Sentry project settings.
SENTRY_DSN=

# Environment label sent with every Sentry event.
# Allowed values: development | staging | production
SENTRY_ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Node.js runtime environment.
# Allowed values: development | test | production
NODE_ENV=development

# Port the Fastify API server listens on.
API_PORT=3001

# Full base URL of the API (used for generating absolute URLs in emails/SMS).
API_BASE_URL=http://localhost:3001

# Full base URL of the web application.
WEB_BASE_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins.
# In production, set this to the exact domain(s) — never use * in production.
CORS_ORIGINS=http://localhost:3000
